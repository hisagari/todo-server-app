<!DOCTYPE html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ToDo App</title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <main class="page">
      <section class="todo-panel">
        <header class="header">
          <div>
            <p class="eyebrow">Server Side Rendering</p>
            <h1>ToDo App</h1>
          </div>
          <p class="count"><%= todos.length %> 件</p>
        </header>

        <form class="add-form" action="/todos" method="POST">
          <input
            type="text"
            name="title"
            placeholder="新しいToDoを入力"
            aria-label="新しいToDo"
            maxlength="120"
            required
          />
          <button type="submit">追加</button>
        </form>

        <% if (todos.length === 0) { %>
          <p class="empty">まだToDoはありません。最初の1件を追加しましょう。</p>
        <% } else { %>
          <ul class="todo-list">
            <% todos.forEach((todo) => { %>
              <li class="todo-item <%= todo.completed ? 'is-completed' : '' %>">
                <form action="/todos/<%= todo.id %>/toggle" method="POST">
                  <button class="toggle-button" type="submit">
                    <span class="checkbox"><%= todo.completed ? '✓' : '' %></span>
                    <span class="todo-title"><%= todo.title %></span>
                  </button>
                </form>

                <form action="/todos/<%= todo.id %>/delete" method="POST">
                  <button class="delete-button" type="submit">削除</button>
                </form>
              </li>
            <% }) %>
          </ul>
        <% } %>
      </section>
    </main>
  </body>
</html>
